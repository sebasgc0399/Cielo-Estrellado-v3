rules_version = '2';
// Colecciones activas del proyecto: ver functions/src/domain/contracts.ts
// Invariante clave: /skies/{skyId}/stars/{starId} es el unico path con read directo desde el cliente.
// Todas las escrituras son via Cloud Functions (Admin SDK, bypasea estas reglas).
// El catch-all al final deniega cualquier coleccion no listada explicitamente.
service cloud.firestore {
  match /databases/{database}/documents {

    function memberRef(skyId) {
      return /databases/$(database)/documents/skies/$(skyId)/members/$(request.auth.uid);
    }

    function isActiveMember(skyId) {
      return request.auth != null
        && exists(memberRef(skyId))
        && get(memberRef(skyId)).data.status == 'active';
    }

    // Users — solo Cloud Functions
    match /users/{uid} {
      allow read, write: if false;

      match /inventory/{itemId} {
        allow read, write: if false;
      }

      match /transactions/{txId} {
        allow read, write: if false;
      }
    }

    // Skies — documento padre solo Cloud Functions
    match /skies/{skyId} {
      allow read, write: if false;

      // Stars — miembros activos pueden leer (onSnapshot)
      match /stars/{starId} {
        allow read: if isActiveMember(skyId);
        allow write: if false;
      }

      // Members — solo Cloud Functions
      match /members/{memberId} {
        allow read, write: if false;
      }
    }

    // Invites — solo Cloud Functions
    match /invites/{inviteId} {
      allow read, write: if false;
    }

    // Payments — solo Cloud Functions
    match /payments/{paymentId} {
      allow read, write: if false;
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
